# macOS
.DS_Store

# Node / Next.js
**/node_modules/
**/.next/

# Python
**/.venv/
**/__pycache__/
**/*.pyc
**/*.pyo
**/.pytest_cache/

# Environment / secrets
**/.env
**/.env.local
**/.env.*.local

# Archives (we keep source, not zipped builds)
*.zip

# Model weights (defensive — these belong in LM Studio, not git)
*.gguf
*.safetensors
*.mlx

# Editor / tool noise
*.swp
*.swo
.idea/
.vscode/

# Claude Code local state (per-user; never share)
**/.claude/settings.local.json
**/.claude/*.lock

# Bench run logs — noisy, large, reproducible from JSONLs.
# Driver scripts (.sh) under .bench-logs/ ARE tracked.
.bench-logs/*.log
.bench-logs/tbench-runs/
