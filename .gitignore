# macOS
.DS_Store

# Node / Next.js
**/node_modules/
**/.next/

# Python
**/.venv/
venvs/
**/__pycache__/
**/*.pyc
**/*.pyo
**/.pytest_cache/

# Environment / secrets
**/.env
**/.env.local
**/.env.*.local

# Archives (we keep source, not zipped builds)
*.zip

# Model weights (defensive — these belong in LM Studio, not git)
*.gguf
*.safetensors
*.mlx

# Editor / tool noise
*.swp
*.swo
.idea/
.vscode/

# Claude Code local state (per-user; never share)
**/.claude/settings.local.json
**/.claude/*.lock

# Bench run logs — noisy, large, regenerable. Everything under a campaign's
# logs/ dir is ignored (raw *.log, driver output, tbench run dirs, GPU traces).
# Tracked scripts live in bench/<campaign>/scripts/, distilled results in
# bench/<campaign>/results/ — see AGENTS.md for the tracked/ignored split.
bench/**/logs/
# Metal GPU capture bundles — enormous (~90 GB; dominated by resident weights),
# regenerable via bench/deepseek-v4-flash/scripts/metal_capture_probe.py. Never commit.
*.gputrace/
